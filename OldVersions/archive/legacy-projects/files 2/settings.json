{
  "model": "claude-opus-4-5",
  "autoMemoryEnabled": true,
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(npx *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push origin main)",
      "Bash(git checkout *)",
      "Bash(git pull)",
      "Bash(docker compose *)",
      "Bash(docker-compose *)",
      "Bash(psql *)",
      "Bash(tsc --noEmit)",
      "Read(*)",
      "Write(*)"
    ],
    "deny": [
      "Bash(cat .env*)",
      "Bash(rm -rf *)",
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(curl * | sh)",
      "Bash(wget * | sh)",
      "Bash(chmod 777 *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [".claude/hooks/pre-tool-check.sh"]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [".claude/hooks/lint-on-save.sh"]
      }
    ]
  },
  "agents": {
    "team-lead": {
      "file": ".claude/agents/team-lead.md",
      "runAt": "session-start"
    },
    "code-reviewer": {
      "file": ".claude/agents/code-reviewer.md",
      "runAt": "pre-commit"
    },
    "compliance-auditor": {
      "file": ".claude/agents/compliance-auditor.md",
      "runAt": "on-request"
    },
    "security-auditor": {
      "file": ".claude/agents/security-auditor.md",
      "runAt": "on-request"
    },
    "test-writer": {
      "file": ".claude/agents/test-writer.md",
      "runAt": "post-feature"
    },
    "doc-writer": {
      "file": ".claude/agents/doc-writer.md",
      "runAt": "post-feature"
    },
    "brain-updater": {
      "file": ".claude/agents/brain-updater.md",
      "runAt": "session-end"
    }
  }
}
