# AgentHarness → HoundShield gateway wiring
# Copy AgentHarness's own .env.example first (cp tools/agent-harness/.env.example tools/agent-harness/.env),
# then set these to benchmark an agent model THROUGH the HoundShield firewall.
#
# Baseline run: point OPENAI_BASE_URL at the model provider directly.
# Firewall run: point OPENAI_BASE_URL at your HoundShield gateway and compare accuracy + latency.

# --- Through the HoundShield gateway (the interesting run) ---
OPENAI_BASE_URL=https://proxy.houndshield.com/v1   # your self-hosted gateway endpoint
OPENAI_API_KEY=hs_live_xxx                          # your HoundShield gateway key
OPENAI_MODEL=gpt-4o                                 # whatever model the gateway forwards to

# --- Tool APIs (optional; enable web search / fetch / sandbox in the ReAct loop) ---
SERPER_API_KEY=
JINA_API_KEY=
E2B_API_KEY=

# Compare the two runs:
#   uv run python -m benchmarks.runner.run_subprocess --benchmark browsecomp --pipeline react_base --profile default
# Accuracy delta ≈ does the firewall change agent outcomes?  Latency delta ≈ the "<10ms" claim, end-to-end.
