# ============================================================
# LEAKWALL — Environment Variables
# Copy to .env.local for local dev. Add to Vercel for production.
# ============================================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # Server-only. Never expose to browser.

# Resend (email)
RESEND_API_KEY=re_...
# Send weekly digest FROM this address (must be verified in Resend)
RESEND_FROM_EMAIL=digest@leakwall.com

# Vercel Cron security (generate with: openssl rand -hex 32)
CRON_SECRET=your-random-secret-here

# App URL (no trailing slash)
NEXT_PUBLIC_APP_URL=https://leakwall.com

# Stripe (add when ready to charge)
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PUBLISHABLE_KEY=pk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
# STRIPE_PRICE_ID_PRO=price_...
# STRIPE_PRICE_ID_TEAM=price_...
# STRIPE_PRICE_ID_BUSINESS=price_...
